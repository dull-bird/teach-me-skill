      "startFrame": 3835,
      "durationFrames": 132,
      "pauseAfterSec": 0.48
    },
    {
      "id": "skills-recap",
      "scene": "workflow-skills",
      "text": "Teach Me Recap uses spaced repetition to help you retain what you learned.",
      "startSec": 132.716,
      "durationSec": 4.392,
