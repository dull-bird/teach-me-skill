      "durationFrames": 153,
      "pauseAfterSec": 0.8
    },
    {
      "id": "quiz-retrieve",
      "scene": "quiz",
      "text": "Knowledge is not yours just because it was written down.",
      "startSec": 143.476,
      "durationSec": 2.928,
      "startFrame": 4304,
      "durationFrames": 88,
      "pauseAfterSec": 0.55
    },
    {
      "id": "quiz-example",
      "scene": "quiz",
      "text": "You have learned it when you can retrieve it and use it when needed.",
      "startSec": 146.954,
      "durationSec": 3.504,
