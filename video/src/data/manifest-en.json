  "segments": [
    {
      "id": "hook-ai",
      "scene": "hook",
      "text": "AI can finish things fast.",
      "startSec": 0.2,
      "durationSec": 2.016,
      "startFrame": 6,
      "durationFrames": 60,
      "pauseAfterSec": 0.58
    },
    {
      "id": "hook-work",
      "scene": "hook",
      "text": "Code, research, configuration.",
      "startSec": 2.7960000000000003,
      "durationSec": 2.736,
      "startFrame": 84,
      "durationFrames": 82,
      "pauseAfterSec": 0.72
    },
    {
      "id": "hook-question",
      "scene": "hook",
      "text": "But once the feature ships, can you still explain why you did it that way?",
      "startSec": 6.252,
      "durationSec": 4.392,
      "startFrame": 188,
      "durationFrames": 132,
      "pauseAfterSec": 0.9
    },
    {
      "id": "intro-reason",
      "scene": "intro",
      "text": "That is why I built Teach Me.",
      "startSec": 11.544,
      "durationSec": 1.8,
      "startFrame": 346,
      "durationFrames": 54,
      "pauseAfterSec": 0.7
    },
    {
      "id": "intro-aim",
      "scene": "intro",
      "text": "I do not want AI to only do my work.",
      "startSec": 14.044,
      "durationSec": 2.544,
      "startFrame": 421,
      "durationFrames": 76,
      "pauseAfterSec": 0.55
    },
    {
      "id": "intro-learn",
      "scene": "intro",
      "text": "I want it to help me notice what is worth learning while the work is happening.",
      "startSec": 17.138,
      "durationSec": 4.056,
      "startFrame": 514,
      "durationFrames": 122,
      "pauseAfterSec": 0.9
    },
    {
      "id": "why-black-box",
      "scene": "why",
      "text": "If every step becomes a black box, we may ship the feature, but we do not keep the judgment.",
      "startSec": 22.094,
      "durationSec": 5.952,
      "startFrame": 663,
      "durationFrames": 179,
      "pauseAfterSec": 0.8
    },
    {
      "id": "why-forget",
      "scene": "why",
      "text": "A few days later, why this design works or how that bug was found becomes blurry again.",
      "startSec": 28.846,
      "durationSec": 5.496,
      "startFrame": 865,
      "durationFrames": 165,
      "pauseAfterSec": 0.82
    },
    {
      "id": "why-explore",
      "scene": "why",
      "text": "AI can certainly help us walk unfamiliar roads.",
      "startSec": 35.162,
      "durationSec": 3.144,
      "startFrame": 1055,
      "durationFrames": 94,
      "pauseAfterSec": 0.5
    },
    {
      "id": "why-blindspots",
      "scene": "why",
      "text": "We have gaps and blind spots. It can explore, explain, and fill them in.",
      "startSec": 38.806,
      "durationSec": 5.184,
      "startFrame": 1164,
      "durationFrames": 156,
      "pauseAfterSec": 0.72
    },
    {
      "id": "why-identity",
      "scene": "why",
      "text": "The problem is not using AI.",
      "startSec": 44.709999999999994,
      "durationSec": 1.848,
      "startFrame": 1341,
      "durationFrames": 55,
      "pauseAfterSec": 0.52
    },
    {
      "id": "why-identity-2",
      "scene": "why",
      "text": "The problem is whether we hand over the identity of thinking and creating along with it.",
      "startSec": 47.077999999999996,
      "durationSec": 4.776,
      "startFrame": 1412,
      "durationFrames": 143,
      "pauseAfterSec": 0.95
    },
    {
      "id": "why-practical",
      "scene": "why",
      "text": "For students or people early in their careers, hands-on practice is already scarce.",
      "startSec": 52.804,
      "durationSec": 5.352,
      "startFrame": 1584,
      "durationFrames": 161,
      "pauseAfterSec": 0.72
    },
    {
      "id": "why-future",
      "scene": "why",
      "text": "Switching tasks, switching jobs, or facing an interview, being able to ask AI is not enough.",
      "startSec": 58.876000000000005,
      "durationSec": 6.792,
      "startFrame": 1766,
      "durationFrames": 204,
      "pauseAfterSec": 0.72
    },
    {
      "id": "why-need",
      "scene": "why",
      "text": "You also need judgment, articulation, and review.",
      "startSec": 66.388,
      "durationSec": 3.6,
      "startFrame": 1992,
      "durationFrames": 108,
      "pauseAfterSec": 0.9
    },
    {
      "id": "story-not-recorder",
      "scene": "story",
      "text": "Teach Me is not a verbose recorder.",
      "startSec": 70.888,
      "durationSec": 2.16,
      "startFrame": 2127,
      "durationFrames": 65,
      "pauseAfterSec": 0.58
    },
    {
      "id": "story-observe",
      "scene": "story",
      "text": "It quietly observes this round of work: coding, configuration, research, or whenever you simply say teach me.",
      "startSec": 73.628,
      "durationSec": 7.584,
      "startFrame": 2209,
      "durationFrames": 228,
      "pauseAfterSec": 0.72
    },
    {
      "id": "story-evidence",
      "scene": "story",
      "text": "What you changed, what you tested, what error you hit, it collects those clues.",
      "startSec": 81.932,
      "durationSec": 5.064,
      "startFrame": 2458,
      "durationFrames": 152,
      "pauseAfterSec": 0.65
    },
    {
      "id": "story-no-interrupt",
      "scene": "story",
      "text": "But it never interrupts you.",
      "startSec": 87.64600000000002,
      "durationSec": 1.752,
      "startFrame": 2629,
      "durationFrames": 53,
      "pauseAfterSec": 0.92
    },
    {
      "id": "workflow-boundary",
      "scene": "workflow-steps",
      "text": "Only when a stretch of work truly ends does it look back.",
      "startSec": 90.31800000000001,
      "durationSec": 3.144,
      "startFrame": 2710,
      "durationFrames": 94,
      "pauseAfterSec": 0.55
    },
    {
      "id": "workflow-signal",
      "scene": "workflow-steps",
      "text": "Not every trace is worth turning into a note.",
      "startSec": 94.01200000000001,
      "durationSec": 2.592,
      "startFrame": 2820,
      "durationFrames": 78,
      "pauseAfterSec": 0.58
    },
    {
      "id": "workflow-judge",
      "scene": "workflow-steps",
      "text": "It asks: is there a concept here that you should actually master?",
      "startSec": 97.18400000000001,
      "durationSec": 3.84,
      "startFrame": 2916,
      "durationFrames": 115,
      "pauseAfterSec": 0.72
    },
    {
      "id": "workflow-structure",
      "scene": "workflow-steps",
      "text": "If so, it explains the key point in one or two sentences, connects it to your system, instead of piling things up randomly.",
      "startSec": 101.74400000000001,
      "durationSec": 8.112,
      "startFrame": 3052,
      "durationFrames": 243,
      "pauseAfterSec": 0.8
    },
    {
      "id": "workflow-review",
      "scene": "workflow-steps",
      "text": "Then it updates your knowledge tree, schedules review, and fills the real gap in your skill map.",
      "startSec": 110.656,
      "durationSec": 5.784,
      "startFrame": 3320,
      "durationFrames": 174,
      "pauseAfterSec": 0.9
    },
    {
      "id": "skills-cycle",
      "scene": "workflow-skills",
      "text": "This loop has four small skills that turn learning into a closed cycle.",
      "startSec": 117.34000000000002,
      "durationSec": 4.536,
      "startFrame": 3520,
      "durationFrames": 136,
      "pauseAfterSec": 0.52
    },
    {
      "id": "skills-core",
      "scene": "workflow-skills",
      "text": "Teach Me gathers evidence, explains the key point, and completes the review.",
      "startSec": 122.39600000000002,
      "durationSec": 4.968,
      "startFrame": 3672,
      "durationFrames": 149,
      "pauseAfterSec": 0.48
    },
    {
      "id": "skills-check",
      "scene": "workflow-skills",
      "text": "Teach Me Check inspects install status and your learning profile.",
      "startSec": 127.84400000000002,
